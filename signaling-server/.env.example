# ── サーバー設定 ─────────────────────────────────────────────
PORT=8080

# ── JWT 設定 ──────────────────────────────────────────────────
# 必ず長くランダムな文字列に変更してください（例: openssl rand -hex 64）
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=24h

# ── Local Agent 共有シークレット ──────────────────────────────
# local-agent の config.json の agentSecret と一致させてください
AGENT_SECRET=change-this-agent-secret

# ── SMTP メール設定 ───────────────────────────────────────────
# 未設定の場合: 認証コードがサーバーのコンソールに表示されます（テスト用）
#
# Gmail の場合:
#   - SMTP_HOST=smtp.gmail.com
#   - SMTP_PORT=587
#   - SMTP_SECURE=false
#   - SMTP_USER=your@gmail.com
#   - SMTP_PASS=アプリパスワード（2段階認証が必要）
#
# SendGrid の場合:
#   - SMTP_HOST=smtp.sendgrid.net
#   - SMTP_PORT=587
#   - SMTP_SECURE=false
#   - SMTP_USER=apikey
#   - SMTP_PASS=SG.xxxxx（APIキー）

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ShogiAnalytics <noreply@example.com>
