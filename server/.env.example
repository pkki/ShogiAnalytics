# ── サーバー設定 ─────────────────────────────────────────────
PORT=3010

# ── JWT 設定 ──────────────────────────────────────────────────
# 必ず長くランダムな文字列に変更 (例: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=24h

# ── SMTP メール設定 ───────────────────────────────────────────
# 未設定の場合: 認証コードがサーバーのコンソールに表示されます（テスト用）
#
# Gmail の場合:
#   SMTP_HOST=smtp.gmail.com / SMTP_PORT=587 / SMTP_SECURE=false
#   SMTP_USER=your@gmail.com / SMTP_PASS=アプリパスワード
#
# SendGrid の場合:
#   SMTP_HOST=smtp.sendgrid.net / SMTP_PORT=587 / SMTP_SECURE=false
#   SMTP_USER=apikey / SMTP_PASS=SG.xxxxx

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ShogiAnalytics <noreply@example.com>

# ── Cloudflare Turnstile ──────────────────────────────────────
# Turnstile シークレットキー (https://dash.cloudflare.com/ で取得)
# 未設定の場合は CAPTCHA 検証をスキップ
TURNSTILE_SECRET_KEY=
