# ── WebRTC モード切り替え ─────────────────────────────────────
# true: WebRTC DataChannel 経由 (local-agent 必須)
# false: 直接 Socket.io 経由 (従来のローカルモード)
VITE_USE_WEBRTC=true

# ── Cloudflare Turnstile ──────────────────────────────────────
# Turnstile サイトキー (https://dash.cloudflare.com/ で取得)
# 未設定の場合は CAPTCHA チェックをスキップ
VITE_TURNSTILE_SITE_KEY=

# ── サーバー URL ──────────────────────────────────────────────
# auth API + WebRTC シグナリング + フロントエンド配信が全て同じサーバー
# VITE_USE_WEBRTC=true の場合のみ使用
VITE_SIGNALING_URL=http://localhost:3010

# ── ローカルエージェント ダウンロード URL ────────────────────
# 未設定の場合は VITE_SIGNALING_URL/downloads/ からの相対URLになります
VITE_AGENT_DOWNLOAD_WIN=
VITE_AGENT_DOWNLOAD_MAC=

# ── Android アプリ ダウンロード URL ─────────────────────────
# GitHub Releases などの APK 直リンクを設定
# 未設定の場合はメニューにダウンロードボタンが表示されません
# 例: https://github.com/yourname/yourrepo/releases/latest/download/app-release.apk
VITE_ANDROID_DOWNLOAD_URL=

# ── Google OAuth ──────────────────────────────────────────────
# Google Cloud Console で OAuth 2.0 クライアントID を取得
# https://console.cloud.google.com/ → APIとサービス → 認証情報
# 未設定の場合は Google ログインボタンが表示されません
VITE_GOOGLE_CLIENT_ID=
